{
  "$schema": "https://your-domain.com/schemas/mytheme-theme.json",
  "name": "mytheme",
  "version": "1.0.0",
  "displayName": "MyTheme",
  "description": "A modern WHMCS client area theme.",
  "author": "Your Studio",

  "requires": {
    "whmcs": ">=9.0",
    "php": ">=8.1",
    "smarty": ">=4.0",
    "ioncube": true
  },

  "provides": {
    "styles": ["default", "dark"],
    "layouts": {
      "main-menu": ["top", "sidebar", "rail"],
      "footer": ["default"]
    },
    "pages": [
      "announcements",
      "clientareadetails",
      "clientareadomains",
      "clientareahome",
      "clientareainvoices",
      "clientareaproducts",
      "homepage",
      "login",
      "supporttickets",
      "viewinvoice",
      "viewticket"
    ],
    "extensions": [],
    "widgets": []
  },

  "commercial": {
    "licenseRequired": true,
    "addonRequired": "MyTheme",
    "renderGuard": "$myTheme.license.canRender",
    "encodedFiles": ["core/mytheme.php"]
  },

  "admin": {
    "managedAreas": ["branding", "styles", "layouts", "pages", "menu", "sidebar", "dashboard", "extensions"],
    "nativeFirst": true
  },

  "deps": {
    "bootstrap": "5.3.0",
    "fontawesome": "6.5.1"
  },

  "rtlLanguages": ["arabic", "hebrew", "farsi"],

  "comment": "This file replaces filesystem-scan-with-Symfony-Finder discovery. The engine reads it once at startup and caches the result. Adding a new style or layout is: (1) add the directory under core/, (2) add its name to the appropriate list here, (3) bump version. The buyer's Configuration cache is invalidated on version bump."
}
