{
  "name": "your-studio/mytheme-whmcs",
  "description": "MyTheme — commercial WHMCS 9 client area theme",
  "type": "whmcs-addon",
  "license": "proprietary",
  "require": {
    "php": ">=8.1",
    "ext-openssl": "*",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-hash": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0",
    "rector/rector": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.65"
  },
  "autoload": {
    "psr-4": {
      "MyTheme\\": "modules/addons/MyTheme/src/",
      "MyTheme\\Resources\\Migrations\\": "modules/addons/MyTheme/resources/migrations/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "stan": "phpstan analyse modules/addons/MyTheme/src --level=6",
    "fix": "php-cs-fixer fix modules/addons/MyTheme/src"
  }
}
